LIBRARIAN_DATABASE_URL=sqlite:///data/librarian.db
LIBRARIAN_LOG_FILE=/data/librarian.log
LIBRARIAN_BOOKS_DIR=/books
LIBRARIAN_HOST_BOOKS_DIR=./Epub-Books
LIBRARIAN_CODEX_BROKER_URL=http://host.docker.internal:8787
LIBRARIAN_ENABLE_CODEX_BROKER=false
LIBRARIAN_EMBEDDING_PROVIDER=ollama
LIBRARIAN_EMBEDDING_MODEL=all-minilm
LIBRARIAN_GENERATION_PROVIDER=ollama
LIBRARIAN_GENERATION_MODEL=llama3.2:3b
LIBRARIAN_OLLAMA_BASE_URL=http://host.docker.internal:11434
LIBRARIAN_OPENSEARCH_URL=http://opensearch:9200
LIBRARIAN_OPENSEARCH_INDEX=librarian-chunks
